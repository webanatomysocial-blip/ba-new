Options -Indexes -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Remove trailing slash
  RewriteRule ^(.*)/$ /$1 [L,R=301]

  # 2. If the requested path + .html exists, serve that file instead
  # (This prevents Apache from serving the directory listing if a .html file shares the same name)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ /$1.html [L]

  # 3. If the requested file or directory exists, serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 4. If nothing matches, serve the Next.js 404 page
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ /404.html [L]
</IfModule>


# Add proper MIME types
<IfModule mod_mime.c>
    AddType text/html .html
    AddType text/css .css
    AddType application/javascript .js
</IfModule>
